package com.company.service;

import com.company.model.Employee;
import org.junit.jupiter.api.Test;

import java.util.*;

import static org.junit.jupiter.api.Assertions.*;

class HierarchyAnalyzerTest {

    @Test
    void shouldDetectLongHierarchy() {

        Map<Integer, Employee> map = new HashMap<>();

        map.put(1, new Employee(1,"A","A",100,null));
        map.put(2, new Employee(2,"B","B",100,1));
        map.put(3, new Employee(3,"C","C",100,2));
        map.put(4, new Employee(4,"D","D",100,3));
        map.put(5, new Employee(5,"E","E",100,4));
        map.put(6, new Employee(6,"F","F",100,5));

        HierarchyAnalyzer analyzer = new HierarchyAnalyzer();

        assertFalse(analyzer.analyze(map).isEmpty());
    }
}